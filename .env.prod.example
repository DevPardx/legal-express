# Copy this to .env.prod and fill in the values
# Generate secrets with: openssl rand -hex 32

NODE_ENV=production
PORT=3000

# Database — must match POSTGRES_USER/POSTGRES_PASSWORD below
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/legal_express

# Docker Compose interpolation for postgres service
POSTGRES_USER=legal_express
POSTGRES_PASSWORD=replace_with_openssl_rand_hex_32

# Redis — service name resolves inside Docker network
REDIS_URL=redis://redis:6379

# The public URL of your server (used for CORS)
# No domain: use http://YOUR_SERVER_IP
FRONTEND_URL=http://YOUR_SERVER_IP

# Auth
JWT_SECRET=replace_with_openssl_rand_hex_32

# Admin seed account (created on first boot if not already in DB)
ADMIN_EMAIL=admin@legalexpress.local
ADMIN_PASSWORD=replace_with_strong_password

# Webhook HMAC secret (optional but recommended)
WEBHOOK_SECRET=replace_with_openssl_rand_hex_32

# Storage & logging
PDF_STORAGE_DIR=./generated
LOG_LEVEL=info
