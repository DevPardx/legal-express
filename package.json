{
  "name": "legal-express",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,yellow \"npm run dev -w apps/frontend\" \"npm run dev -w apps/backend\"",
    "build": "npm run build -w packages/shared && npm run build -w apps/backend && npm run build -w apps/frontend",
    "test": "npm run test -w packages/shared && npm run test -w apps/frontend && npm run test -w apps/backend",
    "test:e2e": "npm run test:e2e -w apps/frontend",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --build",
    "db:migrate": "npm run db:migrate -w apps/backend",
    "db:seed": "npm run db:seed -w apps/backend",
    "docker:up": "docker compose -f infrastructure/compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/compose.yml down",
    "docker:logs": "docker compose -f infrastructure/compose.yml logs -f"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5"
  },
  "devDependencies": {
    "@csstools/css-parser-algorithms": "^4.0.0",
    "@csstools/css-tokenizer": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
