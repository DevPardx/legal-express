<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Legal Express — {{documentType}} Document</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Georgia', serif;
            font-size: 12pt;
            line-height: 1.6;
            color: #1a1a1a;
            background: #fff;
            padding: 2cm 2.5cm;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding-bottom: 20px;
            border-bottom: 2px solid #1e3a8a;
            margin-bottom: 30px;
        }

        .logo-section h1 {
            font-size: 24pt;
            color: #1e3a8a;
            letter-spacing: -0.5px;
        }

        .logo-section p {
            font-size: 10pt;
            color: #64748b;
        }

        .meta-section {
            text-align: right;
            font-size: 9pt;
            color: #64748b;
        }

        .document-title {
            font-size: 18pt;
            color: #1e3a8a;
            font-weight: bold;
            text-align: center;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .section {
            margin-bottom: 24px;
        }

        .section h2 {
            font-size: 11pt;
            color: #1e3a8a;
            font-weight: bold;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 4px;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .field-row {
            display: flex;
            gap: 8px;
            margin-bottom: 8px;
        }

        .field-label {
            font-weight: bold;
            min-width: 140px;
            color: #475569;
            font-size: 10pt;
        }

        .field-value {
            color: #1a1a1a;
            font-size: 10pt;
        }

        .urgent-badge {
            display: inline-block;
            background: #fef3c7;
            border: 1px solid #f59e0b;
            color: #92400e;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 9pt;
            font-weight: bold;
            margin-bottom: 16px;
        }

        .description-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            padding: 12px;
            font-size: 10pt;
            white-space: pre-wrap;
        }

        .footer {
            margin-top: 40px;
            padding-top: 16px;
            border-top: 1px solid #e2e8f0;
            font-size: 8pt;
            color: #94a3b8;
            display: flex;
            justify-content: space-between;
        }

        .signature-block {
            margin-top: 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .signature-line {
            border-top: 1px solid #1a1a1a;
            padding-top: 8px;
            font-size: 9pt;
            color: #475569;
        }
    </style>
</head>

<body>
    <div class="header">
        <div class="logo-section">
            <h1>LEGAL EXPRESS</h1>
            <p>Fast &amp; Reliable Legal Documents</p>
        </div>
        <div class="meta-section">
            <p><strong>Document ID:</strong> {{documentId}}</p>
            <p><strong>Generated:</strong> {{formatDate generatedAt}}</p>
            <p><strong>Reference:</strong> LE-{{year}}-{{referenceNumber}}</p>
        </div>
    </div>

    <div class="document-title">{{uppercase documentType}} Document</div>

    {{#if isUrgent}}
    <p class="urgent-badge">URGENT PROCESSING REQUESTED</p>
    {{/if}}

    <div class="section">
        <h2>Client Information</h2>
        <div class="field-row">
            <span class="field-label">Full Name:</span>
            <span class="field-value">{{firstName}} {{lastName}}</span>
        </div>
        <div class="field-row">
            <span class="field-label">Email:</span>
            <span class="field-value">{{email}}</span>
        </div>
    </div>

    <div class="section">
        <h2>Document Details</h2>
        <div class="field-row">
            <span class="field-label">Type:</span>
            <span class="field-value">{{uppercase documentType}}</span>
        </div>
        {{#if dueDate}}
        <div class="field-row">
            <span class="field-label">Due Date:</span>
            <span class="field-value">{{formatDate dueDate}}</span>
        </div>
        {{/if}}
        {{#if amount}}
        <div class="field-row">
            <span class="field-label">Estimated Amount:</span>
            <span class="field-value">${{amount}}</span>
        </div>
        {{/if}}
    </div>

    {{#if description}}
    <div class="section">
        <h2>Description</h2>
        <div class="description-box">{{description}}</div>
    </div>
    {{/if}}

    {{#if isUrgent}}
    <div class="section">
        <h2>Urgency Justification</h2>
        <div class="description-box">{{urgentReason}}</div>
    </div>
    {{/if}}

    <div class="signature-block">
        <div>
            <div class="signature-line">Client Signature &amp; Date</div>
        </div>
        <div>
            <div class="signature-line">Authorized Representative &amp; Date</div>
        </div>
    </div>

    <div class="footer">
        <span>Legal Express © {{year}} — Confidential Document</span>
        <span>Generated: {{generatedAt}}</span>
    </div>
</body>

</html>